# ============================================================
# THE MC HUB — Production Environment Variables (EXAMPLE)
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ============================================================

# Server Port (Render overrides automatically)
PORT=8080

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<AppName>
MONGODB_DATABASE=mchub

# Security & JWT — generate with: openssl rand -hex 32
JWT_SECRET=<random-64-char-hex>

# Cloudinary — get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# PayOS — get from payos.vn dashboard
PAYOS_CLIENT_ID=<your-client-id>
PAYOS_API_KEY=<your-api-key>
PAYOS_CHECKSUM_KEY=<your-checksum-key>

# MBBank / VietQR
MBBANK_ACCOUNT_NO=<your-account-number>
MBBANK_ACCOUNT_NAME=<your-account-name>
PAYMENT_AMOUNT=20000
PAYMENT_MEMO_PREFIX=MCHUBPREMIUM

# Admin 2FA OTP destination emails (mapped by admin login email index)
ADMIN_OTP_EMAIL_1=<admin1-otp-destination@gmail.com>
ADMIN_OTP_EMAIL_2=<admin2-otp-destination@gmail.com>
ADMIN_OTP_EMAIL_3=<admin3-otp-destination@gmail.com>
ADMIN_OTP_EMAIL_4=<admin4-otp-destination@gmail.com>
ADMIN_OTP_EMAIL_5=<admin5-otp-destination@gmail.com>
ADMIN_OTP_EMAIL_6=<admin6-otp-destination@gmail.com>

# App Environment — prod disables DataSeeder and Swagger
SPRING_PROFILES_ACTIVE=prod
ALLOWED_ORIGINS=https://<your-frontend-domain>.vercel.app
FE_URL=https://<your-frontend-domain>.vercel.app

# AI Service (HuggingFace Space or custom server)
AI_ANALYZE_URL=https://<your-hf-space>.hf.space/analyze-voice
AI_TTS_URL=https://<your-hf-space>.hf.space/generate-mc-voice

# Elasticsearch — leave as localhost if not using on production
ELASTICSEARCH_URIS=http://localhost:9200

# Email (Brevo SMTP) — get from brevo.com
MAIL_USERNAME=<your-smtp-login>@smtp-brevo.com
BREVO_SMTP_KEY=<your-smtp-api-key>
MAIL_FROM=<your-sender-email@gmail.com>
